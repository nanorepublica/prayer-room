{
    "healthchecks": {
        "web": [
            {
                "type": "startup",
                "name": "web check",
                "description": "Checking if the app responds to the /admin endpoint",
                "path": "/admin",
                "attempts": 3
            }
        ]
    },
    "cron": [
        {
            "command": "python manage.py send_moderator_digest",
            "schedule": "0 * * * *"
        },
        {
            "command": "python manage.py send_user_digest --frequency=daily",
            "schedule": "0 8 * * *"
        },
        {
            "command": "python manage.py send_user_digest --frequency=weekly",
            "schedule": "0 8 * * 1"
        }
    ]
}
